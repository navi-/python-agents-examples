# LiveKit Server (Cloud or self-hosted)
# Cloud: wss://your-project.livekit.cloud
# Local: ws://localhost:7880
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# OpenAI API (GPT-5.2-mini)
OPENAI_API_KEY=
LLM_MODEL=gpt-5.2-mini

# Deepgram API (Flux STT)
DEEPGRAM_API_KEY=

# ElevenLabs API (Flash v2.5 TTS)
ELEVEN_API_KEY=
ELEVEN_VOICE=jessica
ELEVEN_MODEL=eleven_flash_v2_5

# Plivo Phone Number (registered on the SIP trunk)
PLIVO_PHONE_NUMBER=

# Plivo SIP Credentials (required for outbound calls only)
# PLIVO_AUTH_ID and PLIVO_AUTH_TOKEN are used as SIP trunk auth
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=

# Plivo Zentrunk Termination SIP Domain (required for outbound calls only)
# Find in Plivo Console → Zentrunk → Outbound Trunks → Termination SIP Domain
# Format: XXXXXXX.zt.plivo.com
PLIVO_SIP_DOMAIN=

# Default country code for phone number parsing (ISO 3166-1 alpha-2)
DEFAULT_COUNTRY_CODE=US

# Server port (outbound management API only — inbound needs no server)
SERVER_PORT=8000

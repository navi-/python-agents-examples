# LiveKit Server
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LiveKit SIP Configuration
# These are auto-created on server startup if LiveKit credentials are set.
# Only set manually if you want to skip auto-configuration.
# LIVEKIT_SIP_URI=<trunk-id>.sip.livekit.cloud
# LIVEKIT_SIP_TRUNK_ID=ST_xxxxx

# OpenAI API (GPT-5.2-mini)
OPENAI_API_KEY=

# LLM Model Configuration
LLM_MODEL=gpt-5.2-mini

# Deepgram API (Flux STT)
DEEPGRAM_API_KEY=

# ElevenLabs API (Flash v2.5 TTS)
ELEVEN_API_KEY=

# ElevenLabs Voice and Model
ELEVEN_VOICE=jessica
ELEVEN_MODEL=eleven_flash_v2_5

# Plivo Credentials (used for webhook management AND as SIP trunk auth)
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=

# Plivo Phone Number (for auto-configuration)
PLIVO_PHONE_NUMBER=

# Plivo SIP Domain (for outbound SIP trunk)
# Default: sip.plivo.com — change for regional endpoints
PLIVO_SIP_DOMAIN=sip.plivo.com

# Default country code for phone numbers without country prefix (ISO 3166-1 alpha-2)
DEFAULT_COUNTRY_CODE=US

# Public URL for webhooks (ngrok URL or production domain)
# Example: https://abc123.ngrok-free.app
PUBLIC_URL=

# Server port (for management API)
SERVER_PORT=8000

# System prompt (leave empty to use default from system_prompt.md)
# SYSTEM_PROMPT=Your custom prompt here

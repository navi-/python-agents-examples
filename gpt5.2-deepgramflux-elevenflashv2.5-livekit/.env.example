# LiveKit Server (Cloud or self-hosted)
# Cloud: wss://your-project.livekit.cloud
# Local: ws://localhost:7880
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LiveKit SIP Endpoint (per-project, found in Project Settings → SIP URI)
# Format: {project_id}.sip.livekit.cloud
# Example: vjnxecm0tjk.sip.livekit.cloud
LIVEKIT_SIP_ENDPOINT=

# OpenAI API (GPT-5.2-mini)
OPENAI_API_KEY=
LLM_MODEL=gpt-5.2-mini

# Deepgram API (Flux STT)
DEEPGRAM_API_KEY=

# ElevenLabs API (Flash v2.5 TTS)
ELEVEN_API_KEY=
ELEVEN_VOICE=jessica
ELEVEN_MODEL=eleven_flash_v2_5

# Plivo Credentials (used for Zentrunk SIP trunk auto-setup)
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=

# Plivo Phone Number (mapped to the inbound SIP trunk on startup)
PLIVO_PHONE_NUMBER=

# Default country code for phone number parsing (ISO 3166-1 alpha-2)
DEFAULT_COUNTRY_CODE=US

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-5.4-mini

# AssemblyAI
ASSEMBLYAI_API_KEY=your-assemblyai-api-key
ASSEMBLYAI_MODEL=u3-rt-pro

# Cartesia
CARTESIA_API_KEY=your-cartesia-api-key
CARTESIA_MODEL=sonic-3
CARTESIA_VOICE_ID=6ccbfb76-1fc6-48f7-b71d-91ac6298247b

# Plivo
PLIVO_AUTH_ID=your-plivo-auth-id
PLIVO_AUTH_TOKEN=your-plivo-auth-token
PLIVO_PHONE_NUMBER=+1234567890

# Server
PUBLIC_URL=https://your-ngrok-url.ngrok.io
SERVER_PORT=8000
DEFAULT_COUNTRY_CODE=US

# Turn Detection Tuning
# Note: END_OF_TURN_CONFIDENCE has no effect with u3-rt-pro (uses punctuation-based detection)
END_OF_TURN_CONFIDENCE=0.4
# Minimum silence (ms) before end-of-turn when model is confident (default: 160)
MIN_END_OF_TURN_SILENCE_MS=160
# Maximum silence (ms) before forced turn end regardless (default: 2400)
MAX_TURN_SILENCE_MS=2400

# Optional: Override system prompt
# SYSTEM_PROMPT=Your custom system prompt here

# OpenAI API
OPENAI_API_KEY=

# OpenAI Model Configuration
OPENAI_MODEL=gpt-5.4-mini

# AssemblyAI API
ASSEMBLYAI_API_KEY=

# Cartesia API
CARTESIA_API_KEY=

# Cartesia Voice ID (default: friendly female voice)
CARTESIA_VOICE=79a125e8-cd45-4c13-8a67-188112f4dd22

# LiveKit Configuration
# LiveKit server URL (e.g., wss://your-project.livekit.cloud)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LiveKit SIP bridge URI (e.g., sip.livekit.cloud)
# Required for routing Plivo calls to LiveKit via SIP
LIVEKIT_SIP_URI=

# Plivo Credentials
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=

# Plivo Phone Number (for auto-configuration)
# The server will automatically configure this number's webhooks on startup
PLIVO_PHONE_NUMBER=

# Default country code for phone numbers without country prefix (ISO 3166-1 alpha-2)
DEFAULT_COUNTRY_CODE=US

# Public URL for webhooks (ngrok URL or production domain)
# Example: https://abc123.ngrok-free.app
PUBLIC_URL=

# Server port
SERVER_PORT=8000

# System prompt (leave empty to use default helpful assistant)
# SYSTEM_PROMPT=Your custom prompt here

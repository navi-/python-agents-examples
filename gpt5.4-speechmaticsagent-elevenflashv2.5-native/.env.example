# Profile: agile | adaptive | smart | external
SPEECHMATICS_PROFILE=adaptive

# ElevenLabs TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# Plivo Credentials
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=

# Plivo Phone Number (for auto-configuration)
PLIVO_PHONE_NUMBER=

# Second Plivo number used only for E2E tests
# PLIVO_TEST_NUMBER=

# Default country code for phone numbers without country prefix (ISO 3166-1 alpha-2)
DEFAULT_COUNTRY_CODE=US

# Public URL for webhooks (ngrok URL or production domain)
PUBLIC_URL=

# Server port
SERVER_PORT=8000

# Silero VAD Configuration
# VAD_START_THRESHOLD=0.85
# VAD_END_THRESHOLD=0.35
# VAD_MIN_SILENCE_MS=500
# VAD_CHUNK_SAMPLES=512
# VAD_PRE_SPEECH_PAD_MS=150

# Pipeline logging verbosity (verbose | normal | quiet)
# LOG_LEVEL=normal

# Observability — JSON logs, file sink, Redis Streams
# LOG_FORMAT=text
# LOG_FILE=
# REDIS_EVENTS_URL=
# REDIS_STREAM_KEY=voice-agent:events
